<?xml version="1.0" encoding="utf-8"?>
<!--
  原始 MJCF/env.xml 的几何替身版本：用 cylinder/box 等基本体替代 STL mesh。
  与 MJCF/env.xml 完全兼容：保留同名 joint/actuator/sensor/site，
  Simulation.py 只需把模型路径切到 MJCF_primitive/env.xml 即可无缝切换。
-->
<mujoco model="inverted_pendulum_primitive">
    <compiler angle="radian" autolimits="true" />
    <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast" density="1.225"
        viscosity="1.8e-5" />

    <visual>
        <global realtime="1" />
        <quality shadowsize="16384" numslices="28" offsamples="4" />
        <headlight diffuse="0.5 0.5 0.5" specular="0.2 0.2 0.2" active="1" />
    </visual>
    <include file="robot_primitive.xml"/>


    <asset>
        <texture type="skybox" file="../MJCF/desert.png"
            gridsize="3 4" gridlayout=".U..LFRB.D.." />
        <texture name="plane" type="2d" builtin="checker" rgb1=".1 .1 .1" rgb2=".9 .9 .9"
            width="512" height="512" mark="cross" markrgb=".8 .8 .8" />
        <material name="plane" reflectance="0.3" texture="plane" texrepeat="1 1" texuniform="true"/>
    </asset>


    <worldbody>
        <geom name="floor" pos="0 0 0" size="0 0 .25" type="plane" material="plane" condim="3" />

        <site name="x_axis_cylinder" type="cylinder" size="0.005 0.08" pos="0.04 0 0"
              axisangle="0 1 0 1.57" rgba="1 0 0 1"/>
        <site name="y_axis_cylinder" type="cylinder" size="0.005 0.08" pos="0 0.04 0"
              axisangle="1 0 0 -1.57" rgba="0 1 0 1"/>
        <site name="z_axis_cylinder" type="cylinder" size="0.005 0.08" pos="0 0 0.04"
              rgba="0 0 1 1"/>
        <site name="origin" type="sphere" size="0.02" rgba="1 1 1 1"/>

        <light directional="true" ambient=".15 .15 .15" pos="30 30 30" dir="0 -.5 -1"
            diffuse=".3 .3 .3" specular=".3 .3 .3" />
    </worldbody>
</mujoco>
